<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorBackground"
    android:fitsSystemWindows="true"
    android:orientation="vertical"
    tools:context=".ui.main.MainActivity">

    <!-- Top bar: history + settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        android:paddingTop="4dp">

        <Space
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHistory"
            style="?attr/materialIconButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/cd_history"
            app:icon="@drawable/ic_history"
            app:iconTint="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettings"
            style="?attr/materialIconButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:contentDescription="@string/cd_settings"
            app:icon="@drawable/ic_settings"
            app:iconTint="?attr/colorOnSurfaceVariant" />
    </LinearLayout>

    <!-- Display -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:animateLayoutChanges="true"
        android:gravity="bottom"
        android:orientation="vertical"
        android:padding="@dimen/calc_display_padding">

        <HorizontalScrollView
            android:id="@+id/scrollExpression"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true"
            android:scrollbars="none">

            <TextView
                android:id="@+id/textExpression"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:maxLines="1"
                android:textColor="?attr/colorOnSurface"
                android:textSize="@dimen/calc_expression_text_size"
                tools:text="12×3+4" />
        </HorizontalScrollView>

        <TextView
            android:id="@+id/textPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:maxLines="1"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:textSize="@dimen/calc_preview_text_size"
            tools:text="40" />
    </LinearLayout>

    <!-- Keypad -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.4"
        android:orientation="vertical"
        android:padding="@dimen/calc_keypad_padding">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnClear"
                style="@style/Widget.NotifyCalc.CalcButton.Action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_clear" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSign"
                style="@style/Widget.NotifyCalc.CalcButton.Action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_sign" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPercent"
                style="@style/Widget.NotifyCalc.CalcButton.Action"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_percent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDivide"
                style="@style/Widget.NotifyCalc.CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_divide" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn7"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_7" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn8"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_8" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn9"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_9" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMultiply"
                style="@style/Widget.NotifyCalc.CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_multiply" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn4"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_4" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn5"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_5" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn6"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_6" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSubtract"
                style="@style/Widget.NotifyCalc.CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_subtract" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn1"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_1" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn2"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_2" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn3"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_3" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdd"
                style="@style/Widget.NotifyCalc.CalcButton.Operator"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_add" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn0"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDecimal"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_decimal" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.NotifyCalc.CalcButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:contentDescription="@string/cd_delete"
                android:text="@string/calc_delete" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEquals"
                style="@style/Widget.NotifyCalc.CalcButton.Equals"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="@dimen/calc_button_margin"
                android:layout_weight="1"
                android:text="@string/calc_equals" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
